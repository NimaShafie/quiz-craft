{
  "name": "QuizCraft Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "customizations": {
    "vscode": {
      "settings": {
        "python.testing.pytestArgs": ["tests"],
        "python.testing.unittestEnabled": false,
        "python.testing.pytestEnabled": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt",
  "postAttachCommand": {
    "server": "streamlit run src/QuizCraft.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {"label": "QuizCraft V1", "onAutoForward": "openPreview"},
    "8502": {"label": "QuizCraft V2 (Hosted)", "onAutoForward": "notify"}
  },
  "forwardPorts": [8501, 8502]
}
