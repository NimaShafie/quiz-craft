# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# Streamlit
.streamlit/

# Data / uploads (don't commit user data)
data/*.pdf
data/*.txt
!data/.gitkeep

# Ollama index (generated at runtime)
INDEX/

# IDE — never commit editor-specific settings
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Secrets — never commit these
.env
*.env
