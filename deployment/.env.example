# QuizCraft environment variables
# Copy this file to deployment/.env and fill in your values.
# All variables are optional for local/personal use — sensible defaults apply.

# ─────────────────────────────────────────────────────────────────────────────
# LLM Backend
# ─────────────────────────────────────────────────────────────────────────────

# Backend to use: ollama (default), openai, anthropic
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# OpenAI-compatible settings (used when LLM_BACKEND=openai)
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_API_KEY=local
# OPENAI_MODEL=local-model

# Anthropic settings (used when LLM_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────────────────────
# Hosting mode (Streamlit rate limiting)
# ─────────────────────────────────────────────────────────────────────────────

# Set to true to enable rate limiting in the Streamlit UI (5 quizzes/hour per IP)
HOSTED_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# Security — only needed for public-facing deployments
# ─────────────────────────────────────────────────────────────────────────────

# Set an API key to protect the REST API endpoints (leave blank to disable auth)
# API_KEY=your-secret-api-key-here

# Restrict CORS origins for the REST API (comma-separated, or * for open)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limit for the REST API (e.g. "10/hour", "100/day" — leave blank to disable)
# API_RATE_LIMIT=10/hour

# Set to true if you are running behind a trusted reverse proxy (nginx, Cloudflare, etc.)
# Enables use of X-Forwarded-For for rate limiting. Do NOT set on bare deployments.
# TRUSTED_PROXY=true

# ─────────────────────────────────────────────────────────────────────────────
# REST API server
# ─────────────────────────────────────────────────────────────────────────────

# Port for the FastAPI REST server (default: 8000)
# API_PORT=8000

# Bind address for the REST server (default: 0.0.0.0)
# API_HOST=0.0.0.0

# Enable uvicorn auto-reload — for development only, never in production
# UVICORN_RELOAD=true

# ─────────────────────────────────────────────────────────────────────────────
# File upload limits
# ─────────────────────────────────────────────────────────────────────────────

# Maximum file upload size in MB (default: 10)
# MAX_UPLOAD_MB=10

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiter internals
# ─────────────────────────────────────────────────────────────────────────────

# Maximum number of unique IPs to track before evicting stale entries (default: 10000)
# RATE_LIMIT_MAX_IPS=10000
